# ==============================================================
# .gitignore — UNet Segmentation API
# ==============================================================

# ── Python & Bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Virtual Environments
.venv/
venv/
env/

# ── Secrets
.env
*.env
.env.*

# ── Model Artifacts & Weights
models/*
!models/.gitkeep
*.pt
*.pth

# ── Dataset (downloaded at runtime via ingest_data())
bottle/
bottle.tar.xz

# ── Jupyter & Research
.ipynb_checkpoints/

# ── Test & Coverage Artifacts
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/

# ── IDE Artifacts
.idea/
.vscode/
*.code-workspace

# ── Build & Distribution
dist/
build/
*.egg-info/

# ── OS Generated Files
.DS_Store
._*
Thumbs.db
